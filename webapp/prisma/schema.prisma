// Elyasya Studio — data model (PRD §8)
// Dev pakai SQLite; produksi tinggal ganti provider ke postgresql.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  name              String
  role              String             @default("admin") // admin | superuser
  createdAt         DateTime           @default(now())
  devices           Device[]
  tokens            ApiToken[]
  studios           Studio[]
  hosts             Host[]
  commissionReports CommissionReport[]
}

// Personal access token untuk extension (menu Extension → Generate Token)
model ApiToken {
  id        String    @id @default(cuid())
  token     String    @unique
  label     String    @default("Extension token")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  devices   Device[]
}

model Device {
  id            String    @id @default(cuid())
  deviceId      String    @unique // UUID dari extension
  label         String    @default("Chrome Browser")
  userAgent     String    @default("")
  accountLabel  String    @default("")
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiTokenId    String?
  apiToken      ApiToken? @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  lastSyncAt    DateTime?
  lastCaptureAt DateTime?
  registeredAt  DateTime  @default(now())
}

model Studio {
  id           String        @id @default(cuid())
  name         String
  location     String        @default("")
  ownerId      String?
  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  hosts        Host[]
  assignments  Assignment[]
  liveSessions LiveSession[]

  @@index([ownerId])
}

model Host {
  id             String          @id @default(cuid())
  name           String
  note           String          @default("")
  contact        String          @default("")
  // Username akun live Shopee host — dipakai auto-tautkan sesi live yang
  // terdeteksi extension (tanpa perlu copy-paste link share tiap live).
  liveUsername   String          @default("")
  // Link share live host (disimpan sekali saat setup) + uid streamer hasil
  // resolve — dipakai auto-deteksi live berikutnya tanpa paste link lagi.
  liveShareLink  String          @default("")
  liveUid        String          @default("")
  // Auto-pin: rotasi pin produk keranjang saat live (urut | acak) tiap N detik.
  autoPinEnabled Boolean         @default(false)
  autoPinSeconds Int             @default(60)
  autoPinMode    String          @default("urut")
  ownerId        String?
  owner          User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  studioId       String?
  studio         Studio?         @relation(fields: [studioId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  shopeeAccounts ShopeeAccount[]
  assignments    Assignment[]
  liveSessions   LiveSession[]
  liveCommands   LiveCommand[]

  @@index([ownerId])
}

model ShopeeAccount {
  id             String    @id @default(cuid())
  hostId         String
  host           Host      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  shopId         String
  // user_id streamer dari callback authorize — WAJIB untuk semua endpoint
  // /api/v2/livestream/* (signature & query pakai user_id, bukan shop_id).
  userId         String    @default("")
  shopName       String    @default("")
  accessToken    String    @default("")
  refreshToken   String    @default("")
  tokenExpiresAt DateTime?
  // livestream | affiliate = OAuth resmi (Partner API, pakai token).
  // cookie = host login via Google/cookie di browser; kontrol keranjang & metrik
  // dijalankan extension memakai cookie host (server tak pernah simpan cookie).
  scope          String    @default("livestream") // livestream | affiliate | cookie
  // Perangkat extension yang terakhir eksekusi perintah cookie (diagnostik).
  connectorDeviceId String @default("")
  // Cookie sesi Shopee host (scope=cookie, di-import via cookie-editor). Dipakai
  // server memanggil API internal Shopee atas nama host — untuk akun AFFILIATE
  // (is_seller=false) yang tidak bisa OAuth Partner sama sekali.
  cookie         String    @default("")
  status         String    @default("active") // active | expired | revoked
  connectedAt    DateTime  @default(now())

  @@unique([hostId, shopId])
}

// Antrian perintah untuk extension mengeksekusi aksi live (add/remove/pin item,
// fetch metrik) memakai cookie host di browser — dipakai saat host terhubung
// mode "cookie" (login Google, tanpa OAuth Partner API). Server tidak pernah
// menyentuh cookie; hanya menitipkan perintah & menerima hasil.
model LiveCommand {
  id              String    @id @default(cuid())
  hostId          String
  host            Host      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  liveSessionId   String    @default("")
  shopeeSessionId String    @default("")
  // add_items | remove_item | pin_item | fetch_metrics
  type            String
  payload         String    @default("{}") // JSON: item_list / item / dsb.
  status          String    @default("pending") // pending | claimed | done | failed
  claimedByDevice String    @default("")
  result          String    @default("{}") // JSON hasil / error dari extension
  attempts        Int       @default(0)
  createdAt       DateTime  @default(now())
  claimedAt       DateTime?
  finishedAt      DateTime?

  @@index([status, hostId])
}

// Endpoint internal live Shopee yang "dipelajari" extension dari trafik live
// yang tertangkap (add item, pin/show item, metrik real-time). Karena Shopee
// tidak mendokumentasikannya, template ini dipakai extension untuk me-replay
// perintah dari dashboard. Di-share lintas host (endpoint sama untuk semua).
model ShopeeLiveEndpoint {
  id           String   @id @default(cuid())
  // add_item | remove_item | show_item | metrics
  action       String   @unique
  method       String   @default("POST")
  urlTemplate  String   // mis. https://live.shopee.co.id/api/v1/session/{session_id}/item
  bodyTemplate String   @default("") // JSON template dgn placeholder, "" = GET/query
  sampleBody   String   @default("{}") // contoh payload asli (diagnostik)
  learnedAt    DateTime @default(now())
}

model Product {
  id             String            @id @default(cuid())
  itemId         String
  shopId         String
  name           String
  imageUrl       String            @default("")
  price          Float             @default(0)
  commissionRate Float             @default(0) // persen, mis. 5.5
  sold           Int               @default(0)
  sold30d        Int               @default(0) // penjualan 30 hari terakhir
  rating         Float             @default(0) // bintang 0-5
  trend          Float             @default(0) // % perubahan penjualan 30 hari
  revenue        Float             @default(0)
  source         String            @default("extension") // extension | manual
  firstSeenAt    DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  rawPayload     String            @default("{}") // JSON string capture extension
  collection     CollectionEntry?
  sessionItems   LiveSessionItem[]

  @@unique([itemId, shopId])
}

// Folder untuk memisahkan produk di Koleksi (mis. per kategori/host)
model CollectionFolder {
  id        String            @id @default(cuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  entries   CollectionEntry[]
}

model CollectionEntry {
  id          String            @id @default(cuid())
  productId   String            @unique
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  tags        String            @default("") // comma-separated
  folderId    String?
  folder      CollectionFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  addedAt     DateTime          @default(now())
  addedBy     String            @default("")
  assignments Assignment[]
}

model Assignment {
  id                String            @id @default(cuid())
  collectionEntryId String
  collectionEntry   CollectionEntry   @relation(fields: [collectionEntryId], references: [id], onDelete: Cascade)
  targetType        String // studio | host
  studioId          String?
  studio            Studio?           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  hostId            String?
  host              Host?             @relation(fields: [hostId], references: [id], onDelete: Cascade)
  status            String            @default("pending") // pending | pushed | removed
  assignedAt        DateTime          @default(now())
  sessionItems      LiveSessionItem[]
}

model LiveSession {
  id              String            @id @default(cuid())
  shopeeSessionId String            @default("")
  hostId          String
  host            Host              @relation(fields: [hostId], references: [id], onDelete: Cascade)
  studioId        String?
  studio          Studio?           @relation(fields: [studioId], references: [id], onDelete: SetNull)
  status          String            @default("not_started") // not_started | live | ended
  title           String            @default("")
  pushUrl         String            @default("")
  pushKey         String            @default("")
  shareUrl        String            @default("")
  playUrl         String            @default("") // stream FLV dari get_session_detail — dipakai player panel
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime          @default(now())
  items           LiveSessionItem[]
  snapshots       MetricSnapshot[]
}

model LiveSessionItem {
  id                 String      @id @default(cuid())
  liveSessionId      String
  liveSession        LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  productId          String
  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  itemNo             Int         @default(0)
  isShowing          Boolean     @default(false)
  // Metrik per-item dari get_session_item_metric (di-sync berkala saat live)
  soldItems          Int         @default(0)
  itemClicks         Int         @default(0)
  atc                Int         @default(0)
  pushedAt           DateTime    @default(now())
  sourceAssignmentId String?
  sourceAssignment   Assignment? @relation(fields: [sourceAssignmentId], references: [id], onDelete: SetNull)

  @@unique([liveSessionId, productId])
}

model MetricSnapshot {
  id                 String      @id @default(cuid())
  liveSessionId      String
  liveSession        LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  capturedAt         DateTime    @default(now())
  gmv                Float       @default(0)
  orders             Int         @default(0)
  ccu                Int         @default(0)
  peakCcu            Int         @default(0)
  views              Int         @default(0)
  atc                Int         @default(0)
  ctr                Float       @default(0)
  co                 Float       @default(0)
  likes              Int         @default(0)
  comments           Int         @default(0)
  shares             Int         @default(0)
  avgViewingDuration Float       @default(0)
  estCommission      Float       @default(0)
}

model CommissionReport {
  id               String   @id @default(cuid())
  ownerId          String?
  owner            User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  shopeeAccountId  String   @default("")
  orderId          String   @default("")
  productItemId    String   @default("")
  commissionAmount Float    @default(0)
  status           String   @default("pending") // pending | approved | rejected
  period           String   @default("")
  syncedAt         DateTime @default(now())

  @@index([ownerId])
}

// Keyword trending (dari capture extension) — untuk /api/research/trending
model TrendKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  count     Int      @default(1)
  lastSeen  DateTime @default(now())
}
